# =============================================================================
# VOS Studio MCP — Environment variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
MCP_SERVER_NAME=vos-studio-mcp
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000
# Public HTTPS origin used in OAuth metadata when the server is behind a tunnel/proxy.
MCP_PUBLIC_BASE_URL=
DEBUG=false
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database — Supabase Postgres (ADR-0007, ADR-0020, ADR-0040)
# Format: postgresql+asyncpg://user:password@host:port/database
#
# In production DATABASE_URL MUST use a NOSUPERUSER / NOBYPASSRLS role so that
# Row-Level Security is a real enforcement boundary (ADR-0040). Do NOT use the
# Supabase service_role / postgres superuser here.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:54322/postgres

# Privileged connection for cross-tenant system tasks (ADR-0040 step 2):
# scheduled rollups/cleanup, the global provider-budget ledger, and the audit
# writer. MUST use a BYPASSRLS role (e.g. Supabase service_role) in production.
# Leave empty in single-role dev/test to fall back to DATABASE_URL.
DATABASE_PRIVILEGED_URL=

# -----------------------------------------------------------------------------
# Supabase — auth and storage client (ADR-0007, ADR-0008)
# Service role key is server-side only. Never expose it to browsers, clients, or MCP responses.
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Auth — OAuth 2.1 (ADR-0019)
#
# Choose ONE of the two validation modes below:
#
# Mode 1 — JWKS / RS256 (Supabase Auth with RS256 keys, or any OAuth 2.1 IdP)
#   Set OAUTH_ISSUER_URL. The server fetches /.well-known/jwks.json automatically.
#   For Supabase: Project Settings → Auth → JWT Settings → "Enable RS256 keys"
#
# Mode 2 — Supabase HS256 (default Supabase projects)
#   Set SUPABASE_JWT_SECRET (Project Settings → API → JWT Secret).
#   Only accepts tokens with role=authenticated. JWKS takes precedence if
#   OAUTH_ISSUER_URL is also configured.
# -----------------------------------------------------------------------------
OAUTH_ISSUER_URL=https://your-project.supabase.co/auth/v1
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
# Optional but recommended: expected JWT audience. When set, bearer tokens whose
# `aud` claim does not contain this value are rejected (prevents a token issued
# by the same IdP for another resource from being replayed against this server).
OAUTH_AUDIENCE=
# Native MCP OAuth server for ChatGPT connectors. Prefer this for remote MCP.
MCP_OAUTH_ISSUER_URL=
MCP_OAUTH_SIGNING_KEY=
MCP_OAUTH_AUTHORIZATION_SECRET=
MCP_OAUTH_ALLOWED_REDIRECT_URIS=https://chatgpt.com/connector/oauth/*
MCP_OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
MCP_OAUTH_AUTH_CODE_TTL_SECONDS=300
SUPABASE_JWT_SECRET=
# Static bearer token for local development only — never use in production
DEV_BEARER_TOKEN=
# Fixed client_id injected when DEV_BEARER_TOKEN is used — dev only
DEV_CLIENT_ID=00000000-0000-0000-0000-000000000001

# -----------------------------------------------------------------------------
# Job queue — Celery + Redis (ADR-0021)
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Asset storage — Cloudflare R2 or S3-compatible (ADR-0008)
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=r2
STORAGE_ENDPOINT=https://your-account.r2.cloudflarestorage.com
STORAGE_BUCKET=vos-studio-assets
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_PUBLIC_BASE_URL=https://assets.vosstudio.com

# -----------------------------------------------------------------------------
# Provider API keys (ADR-0009, ADR-0016)
# Only required when using api_credits mode for the respective provider.
# -----------------------------------------------------------------------------
HIGGSFIELD_API_KEY=
HIGGSFIELD_MCP_ENABLED=false
HIGGSFIELD_MCP_URL=https://mcp.higgsfield.ai/mcp
HIGGSFIELD_MCP_ACCESS_TOKEN=
FREEPIK_API_KEY=
MAGNIFIC_API_KEY=

# -----------------------------------------------------------------------------
# Webhooks (ADR-0028)
# Shared secret for validating incoming provider webhook signatures.
# -----------------------------------------------------------------------------
WEBHOOK_SECRET_HIGGSFIELD=
WEBHOOK_SECRET_FREEPIK=
WEBHOOK_SECRET_MAGNIFIC=

# Shared secret for signing outbound webhook notifications to clients (Issue #33).
# Set this to a random hex string. If empty, no signature header is sent.
OUTBOUND_WEBHOOK_SECRET=

# Rate limiting (Redis-backed sliding window, defaults are generous for dev)
# Set RATE_LIMIT_ENABLED=false to disable completely in local development.
RATE_LIMIT_ENABLED=true
PROVIDER_DAILY_LIMIT_USD=5.0

# -----------------------------------------------------------------------------
# Observability (ADR-0030)
# Leave SENTRY_DSN empty to disable Sentry in local development.
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
